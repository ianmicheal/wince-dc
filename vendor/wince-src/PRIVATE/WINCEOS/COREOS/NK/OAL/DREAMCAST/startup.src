	.HEADING "Dreamcast SH-4 kernel startup"
;++
;
; startup.src - Dreamcast (Sega Katana) OAL boot entry.
;
; RECONSTRUCTED (not from the leak) from the shipped SDK kernel
; release\debug\nknodbg.exe (_StartUp @ 0x8C00B2B0). The leak is WINCEOS-only;
; the hal:fwinit.obj that supplied StartUp lived in Sega's closed BSP. See
; OAL-NOTES.md.
;
; The DC IPL / 1ST_READ loader has already copied the RAMIMAGE into RAM and
; jumped here. Real SH-4 bring-up (VBR, cache CCR, MMU/TLB, stacks) is done by
; KernelStart (nk:shexcept.obj). This stub plants the Flycast WinCE detector,
; blocks exceptions (SR.BL=1), and transfers to KernelStart.
;
; Environment: privileged, MMU off, called once at boot. Never returns.
;
;--
	.include "ksshx.h"

	.import	KernelStart

	LEAF_ENTRY StartUp
	ALTERNATE_ENTRY _StartUp	; linker /entry:StartUp resolves the C-decorated _StartUp

	; Plant Flycast's WinCE detector: write UTF-16 "SH-4 Kernel" to 0x8C0110A8
	; and 0x8C011118 via the UNCACHED P2 alias (0xAC01...) so it reaches RAM
	; regardless of cache state, before KernelStart enables the MMU - Flycast's
	; mmu_set_state() only emulates the full MMU when it sees that string.
	mov.l	pMagicA, r2		; r2 = 0xAC0110A8
	bsr	PlantMagic
	nop
	mov.l	pMagicB, r2		; r2 = 0xAC011118
	bsr	PlantMagic
	nop

	stc	SR, r0			; r0 = current SR
	mov.l	SRSetBL, r2		; r2 = 0x10000000 (BL)
	mov.l	pKernelStart, r1	; r1 = &KernelStart
	or	r2, r0			; SR |= BL  (block all exceptions)
	ldc	r0, SR
	jmp	@r1			; -> KernelStart (does VBR/cache/MMU/stacks)
	nop

	.align	4
SRSetBL:	.data.l	H'10000000	; SR.BL = 1
pKernelStart:	.data.l	KernelStart
pMagicA:	.data.l	H'AC0110A8	; uncached alias of 0x8C0110A8
pMagicB:	.data.l	H'AC011118	; uncached alias of 0x8C011118
	ENTRY_END StartUp

;
; PlantMagic - write the 11-wchar UTF-16 "SH-4 Kernel" to [r2]. Clobbers r0,r3,r6.
;
	LEAF_ENTRY PlantMagic
	mova	MagicStr, r0		; r0 = &MagicStr (must be 4-aligned)
	mov	r0, r3
	mov	#11, r6
pmloop:	mov.w	@r3+, r0
	mov.w	r0, @r2
	add	#2, r2
	dt	r6
	bf	pmloop
	rts
	nop
	.align	4
MagicStr:	.data.w	H'0053, H'0048, H'002D, H'0034, H'0020, H'004B
		.data.w	H'0065, H'0072, H'006E, H'0065, H'006C
	ENTRY_END PlantMagic

;
; OEMNMI - non-maskable interrupt hook. shexcept.src imports it as a bare asm
; symbol (no C underscore), so it lives here. Stub: return (no NMI sources wired).
;
	LEAF_ENTRY OEMNMI
	rts
	nop
	ENTRY_END OEMNMI

	.end
