; ---------------------------------------------------------------------------
;  DCWin shell autorun — in the SDK source gemini.reg
;  (C:\wcedreamcast\release\<flavor>\gemini.reg). sysstart.exe reads
;  HKLM\init "Autorun" and launches it last. The IMGNOSHELL guard drops the
;  devkit CESH shell.exe (it faults in emulation), leaving dcshell as the shell.
;  Context shown for placement; the line to ensure is the "Autorun" one.
; ---------------------------------------------------------------------------
[HKEY_LOCAL_MACHINE\init]

IF CONFIGTOOL !
    "Autorun"="dcshell.exe"
ENDIF

IF IMGNOSHELL !
    "Launch11"="shell.exe"
ENDIF

;   ... (existing Launch40/wdevice, Depend40, etc. follow unchanged) ...
